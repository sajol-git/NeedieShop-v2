{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "price": { "type": "number" },
        "compareAtPrice": { "type": "number" },
        "featureImage": { "type": "string" },
        "gallery": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "stock": { "type": "number" },
        "status": { "type": "string", "enum": ["published", "draft"] },
        "isFeatured": { "type": "boolean" },
        "isFlashSale": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug", "price", "category", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "subtotal": { "type": "number" },
        "shippingFee": { "type": "number" },
        "advancePayment": { "type": "number" },
        "dueAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "customerInfo": { "type": "object" },
        "trackingNumber": { "type": "string" },
        "trackingHistory": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "status", "customerInfo", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "photo": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Brand": {
      "title": "Brand",
      "description": "A product brand",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "photo": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "suspect"] },
        "isProfileCompleted": { "type": "boolean" },
        "isEmailVerified": { "type": "boolean" },
        "isPhoneVerified": { "type": "boolean" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "ipAddress": { "type": "string" }
      },
      "required": ["id", "email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application settings",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "object" }
      },
      "required": ["key", "value"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Collection of products" },
    "orders": { "schema": "Order", "description": "Collection of orders" },
    "categories": { "schema": "Category", "description": "Collection of categories" },
    "brands": { "schema": "Brand", "description": "Collection of brands" },
    "users": { "schema": "User", "description": "Collection of users" },
    "settings": { "schema": "Settings", "description": "Collection of settings" }
  }
}
